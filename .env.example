# ─── Model providers ────────────────────────────────────────────────────────
# IMPORTANT: create a SEPARATE Anthropic workspace and OpenAI project for this
# demo, each with its own low spend cap, so demo abuse can never affect your
# personal API usage or produce a surprise bill. See HARDENING_NOTES.md.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Per-user spend cap ─────────────────────────────────────────────────────
# Maximum spend, in USD, per authenticated user before they're blocked. Shared
# across Google and GitHub logins (both map to one Supabase user). Default 0.10.
PER_USER_SPEND_CAP_USD=0.10

# ─── Price table (per MILLION tokens, USD) ──────────────────────────────────
# Used only for cost accounting against the cap. Update if provider prices move.
PRICE_SONNET_INPUT_PER_M=3.00
PRICE_SONNET_OUTPUT_PER_M=15.00
PRICE_EMBED_PER_M=0.02
